{
  "name": "droneline-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"vite --port=5173\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:vite": "vite --port=5173",
    "dev:electron": "electron .",
    "build": "vite build && npm run build:electron && electron-builder",
    "build:vite": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node electron/rename-electron-output.cjs",
    "verify:dist-paths": "node scripts/verify-dist-paths.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@mapbox/shp-write": "^0.4.3",
    "@tailwindcss/vite": "^4.1.14",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/turf": "^7.3.4",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-is-dev": "^3.0.0",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "shpjs": "^6.2.0",
    "tailwind-merge": "^3.5.0",
    "tokml": "^0.4.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.droneline.planner",
    "productName": "Austhai UAV Line Planner",
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "public/icon.png",
      "public/icon.ico"
    ],
    "asarUnpack": [
      "dist/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false,
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
